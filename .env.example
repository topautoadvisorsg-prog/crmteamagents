# ─── Core ────────────────────────────────────────────────────────────────────
# On Railway: only PORT matters (Railway injects it). Local dev uses these:
INGESTION_PORT=3000
ADMIN_PORT=3001
EXECUTE_PORT=3002

# ─── Admin Security ───────────────────────────────────────────────────────────
# Set ADMIN_TOKEN to protect the admin API with a static token.
# Leave empty in dev (open access). Always set in production.
ADMIN_TOKEN=

# ─── Testing ──────────────────────────────────────────────────────────────────
# Set to true to allow outreach on weekends (useful for pipeline testing)
DISABLE_WEEKEND_POLICY=false

# ─── Redis (required) ─────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Security — must match CRM exactly ───────────────────────────────────────
# Used to sign/verify JWTs between agents and CRM
AGENT_INTERNAL_TOKEN=sk-smartklix-internal-change-me
# Used to verify incoming webhooks from CRM to agents
AGENT_WEBHOOK_SECRET=sk-smartklix-webhook-change-me
# Used by auth-middleware for incoming requests to ingestion service
INTERNAL_TOKEN=sk-smartklix-internal-change-me

# ─── CRM URLs ─────────────────────────────────────────────────────────────────
# Where agents call back after executing a CRM-dispatched action
CRM_CALLBACK_URL=http://localhost:5000/api/agent/callback
# Where agents call back after processing a lead intake event
CRM_SYNC_URL=http://localhost:5000/api/intake/sync

# ─── ClickHouse (optional) ───────────────────────────────────────────────────
# Leave empty to disable observability logging
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── SDKs — fill in to enable real execution ─────────────────────────────────
# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=SmartKlix <noreply@yourdomain.com>

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=

# Calendly (booking)
CALENDLY_API_KEY=

# Stripe (payments — future)
STRIPE_SECRET_KEY=

# ─── Lead Sourcer ─────────────────────────────────────────────────────────────
# Without GOOGLE_PLACES_API_KEY: runs in demo mode (realistic fake construction leads)
# With key: searches live Google Places for construction companies with no website
GOOGLE_PLACES_API_KEY=

# How often the sourcer runs (in minutes). Default: 30
# Lower for testing (e.g. 5), raise for production (e.g. 60)
SEARCH_INTERVAL_MINUTES=30

# ─── Token Cost Overrides ─────────────────────────────────────────────────────
# Default: claude-haiku-4-5 pricing. Override if you switch models.
TOKEN_COST_INPUT_PER_M=0.80
TOKEN_COST_OUTPUT_PER_M=4.00
