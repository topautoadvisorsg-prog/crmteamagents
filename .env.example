# ─── Core ────────────────────────────────────────────────────────────────────
INGESTION_PORT=3000
ADMIN_PORT=3001
EXECUTE_PORT=3002

# ─── Redis (required) ─────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Security — must match CRM exactly ───────────────────────────────────────
# Used to sign/verify JWTs between agents and CRM
AGENT_INTERNAL_TOKEN=sk-smartklix-internal-change-me
# Used to verify incoming webhooks from CRM to agents
AGENT_WEBHOOK_SECRET=sk-smartklix-webhook-change-me
# Used by auth-middleware for incoming requests to ingestion service
INTERNAL_TOKEN=sk-smartklix-internal-change-me

# ─── CRM URLs ─────────────────────────────────────────────────────────────────
# Where agents call back after executing a CRM-dispatched action
CRM_CALLBACK_URL=http://localhost:5000/api/agent/callback
# Where agents call back after processing a lead intake event
CRM_SYNC_URL=http://localhost:5000/api/intake/sync

# ─── ClickHouse (optional) ───────────────────────────────────────────────────
# Leave empty to disable observability logging
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── SDKs — fill in to enable real execution ─────────────────────────────────
# Resend (email)
RESEND_API_KEY=

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=

# Calendly (booking)
CALENDLY_API_KEY=

# Stripe (payments — future)
STRIPE_SECRET_KEY=
